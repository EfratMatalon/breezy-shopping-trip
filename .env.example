# Supabase project credentials (Phase 2 will wire these into the frontend).
# Copy to .env.local and fill in values from your Supabase project settings.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Assistant (Phase 6.0) — frontend feature flag only. The Gemini API key
# is never a Vite env var — it lives exclusively as a Supabase Edge Function
# secret (GEMINI_API_KEY), set via `supabase secrets set`, never in this file.
VITE_AI_ENABLED=
